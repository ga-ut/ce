{
  "name": "@ga-ut/ce",
  "version": "2.0.0",
  "description": "Custom Element library with state binding and optional routing",
  "license": "ISC",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.mjs",
      "require": "./dist/web/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/core/index.ts src/web/index.ts --format esm,cjs --dts --clean",
    "pack:check": "npm pack --dry-run --cache ./.npm-pack-cache"
  }
}
